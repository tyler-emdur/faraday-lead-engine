# ─────────────────────────────────────────
# AI PROVIDER (OpenAI-compatible — pick one)
# ─────────────────────────────────────────
# Groq (free tier — recommended):
#   https://console.groq.com → get API key → sign up free
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=gsk_...
AI_MODEL=llama-3.3-70b-versatile

# Other free options:
#   OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1 (free models available)
#   Together AI: AI_BASE_URL=https://api.together.xyz/v1
#   Ollama (local): AI_BASE_URL=http://localhost:11434/v1  AI_API_KEY=ollama

# ─────────────────────────────────────────
# SUPABASE (free tier)
# Create project at https://supabase.com, run db/schema.sql
# ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─────────────────────────────────────────
# TWILIO — SMS notifications & follow-ups
# https://twilio.com (free trial available)
# ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+13035550123

# ─────────────────────────────────────────
# RESEND — Email follow-ups & team alerts
# https://resend.com (free tier: 100 emails/day)
# ─────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=leads@yourdomain.com

# ─────────────────────────────────────────
# YOUR NOTIFICATIONS (Tyler — lead gen contractor)
# ─────────────────────────────────────────
# TYLER_PHONE: Your cell. Instant SMS when a lead comes in + when a storm hits.
TYLER_PHONE=+13035550100
# TYLER_EMAIL: Your email. Storm alerts with full copy-paste post templates.
TYLER_EMAIL=you@gmail.com
# Fallbacks (legacy — TYLER_ vars take priority)
TEAM_PHONE=+13035550100
TEAM_EMAIL=team@faradayconstruction.com

# ─────────────────────────────────────────
# SOCIAL MEDIA AUTO-POSTING
# ─────────────────────────────────────────
FACEBOOK_PAGE_ACCESS_TOKEN=EAA...
FACEBOOK_PAGE_ID=123456789
GBP_LOCATION_ID=accounts/123/locations/456

# ─────────────────────────────────────────
# CRON SECURITY
# Vercel auto-sets this — or generate a random string for local testing
# ─────────────────────────────────────────
CRON_SECRET=your-random-secret-here

# ─────────────────────────────────────────
# COMPANY INFO (shown in emails, templates, chat)
# ─────────────────────────────────────────
NEXT_PUBLIC_COMPANY_PHONE=(303) 555-0123
NEXT_PUBLIC_COMPANY_EMAIL=info@faradayconstruction.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ─────────────────────────────────────────
# ADMIN DASHBOARD
# Note: This is exposed in the browser bundle — use a strong password
# ─────────────────────────────────────────
NEXT_PUBLIC_ADMIN_PASSWORD=change-this-password
